{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "voice-notes",
  "main": "worker/index.js",
  "compatibility_date": "2026-07-03",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
